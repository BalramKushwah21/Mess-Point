generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================= Authentication & Owner Data =================
model Owner {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  whatsapp  String   @unique
  password  String
  mess      Mess?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ================= Tenant (Mess Owner) Model =================
model Mess {
  id               Int      @id @default(autoincrement())
  customDomain     String   @unique
  messName         String
  address          String?
  subscriptionPlan String
  
  ownerId          Int      @unique
  owner            Owner    @relation(fields: [ownerId], references: [id])
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // Relations (Is mess ke andar kya-kya hai)
  customers        Customer[]
  employees        Employee[]
  parcels          Parcel[]
  paymentHistory   PaymentHistory[]
}

// ================= Core Modules Data =================

// 1. Customer & Membership Management
model Customer {
  id              Int      @id @default(autoincrement())
  messId          Int      
  name            String
  phone           String
  address         String
  plan            String   
  mealsPerDay     Int      
  deliveryType    String   
  startDate       DateTime 
  paymentDate     DateTime?
  numberOfDays    Int      
  daysLeft        Int      
  paidAmount      Int       @default(0)
  totalAmount     Int      @default(0) 
  remainingAmount Int      @default(0) 
  paymentStatus   String   
  
  mess            Mess     @relation(fields: [messId], references: [id])
  parcels         Parcel[]
  paymentHistory  PaymentHistory[] 
}

// 2. Lifetime Payment & Renewal History Table
model PaymentHistory {
  id              Int      @id @default(autoincrement())
  customerId      Int
  messId          Int
  transactionDate DateTime @default(now()) 
  
  addedDays       Int      @default(0) 
  billAmount      Int      @default(0) 
  paidAmount      Int      @default(0) 
  remainingAmount Int      @default(0) 
  paymentStatus   String

  customer        Customer @relation(fields: [customerId], references: [id])
  mess            Mess     @relation(fields: [messId], references: [id])
}

// 3. Employee Management (Staff)
model Employee {
  id         Int    @id @default(autoincrement())
  messId     Int    
  name       String
  role       String 
  baseSalary Int
  
  mess       Mess   @relation(fields: [messId], references: [id])
}

// 4. Parcel & Delivery Section
model Parcel {
  id         Int      @id @default(autoincrement())
  messId     Int      
  customerId Int
  address    String   
  status     String   @default("Pending")
  
  mess       Mess     @relation(fields: [messId], references: [id])
  customer   Customer @relation(fields: [customerId], references: [id])
}