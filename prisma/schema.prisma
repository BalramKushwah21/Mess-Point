generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================= Authentication & Owner Data =================
model Owner {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  whatsapp  String   @unique
  password  String
  mess      Mess?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ================= Tenant (Mess Owner) Model =================
model Mess {
  id                  Int      @id @default(autoincrement())
  customDomain        String   @unique
  messName            String
  address             String?
  subscriptionPlan    String
  
  subscriptionEndDate DateTime 
  
  ownerId             Int      @unique
  // CASCADE ADDED: Owner delete hoga toh Mess delete ho jayegi
  owner               Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  customers           Customer[]
  employees           Employee[]
  parcels             Parcel[]
  paymentHistory      PaymentHistory[]
  platformPayments    PlatformPayment[] 
}

// ================= Core Modules Data =================

// 1. Customer & Membership Management
model Customer {
  id              Int      @id @default(autoincrement())
  messId          Int      
  name            String
  phone           String
  address         String
  plan            String   
  mealsPerDay     Int      
  deliveryType    String   
  startDate       DateTime 
  paymentDate     DateTime?
  numberOfDays    Int      
  daysLeft        Int      
  paidAmount      Int      @default(0)
  totalAmount     Int      @default(0) 
  remainingAmount Int      @default(0) 
  paymentStatus   String   
  
  // CASCADE ADDED: Mess delete hogi toh Customer delete ho jayega
  mess            Mess     @relation(fields: [messId], references: [id], onDelete: Cascade)
  parcels         Parcel[]
  paymentHistory  PaymentHistory[] 
}

// 2. Lifetime Payment & Renewal History Table
model PaymentHistory {
  id              Int      @id @default(autoincrement())
  customerId      Int
  messId          Int
  transactionDate DateTime @default(now()) 
  
  addedDays       Int      @default(0) 
  billAmount      Int      @default(0) 
  paidAmount      Int      @default(0) 
  remainingAmount Int      @default(0) 
  paymentStatus   String

  // CASCADE ADDED
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  mess            Mess     @relation(fields: [messId], references: [id], onDelete: Cascade)
}

// 3. Employee Management (Staff)
model Employee {
  id         Int    @id @default(autoincrement())
  messId     Int    
  name       String
  role       String 
  baseSalary Int
  
  // CASCADE ADDED
  mess       Mess   @relation(fields: [messId], references: [id], onDelete: Cascade)
}

// 4. Parcel & Delivery Section
model Parcel {
  id         Int      @id @default(autoincrement())
  messId     Int      
  customerId Int
  address    String   
  status     String   @default("Pending")
  
  // CASCADE ADDED
  mess       Mess     @relation(fields: [messId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// ================= SaaS Platform Subscriptions Data =================

// 5. Razorpay Payments (Mess Owner -> Mess-Point Platform)
model PlatformPayment {
  id                Int      @id @default(autoincrement())
  messId            Int
  
  razorpayOrderId   String   @unique 
  razorpayPaymentId String?  @unique 
  amount            Int      
  status            String   @default("PENDING") 
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // CASCADE ADDED
  mess              Mess     @relation(fields: [messId], references: [id], onDelete: Cascade)
}