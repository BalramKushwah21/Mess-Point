// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User Account (Multi-tenant owner)
model User {
  id              String          @id @default(cuid())
  email           String          @unique
  phone           String          @unique
  passwordHash    String?
  firstName       String
  lastName        String
  businessName    String
  verified        Boolean         @default(false)
  status          String          @default("active") // active, suspended, deleted
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  subscriptions   Subscription[]
  messes          Mess[]
  
  @@index([email])
  @@index([phone])
}

// Subscription Plans
model Plan {
  id              String          @id @default(cuid())
  name            String          @unique // "Free", "Basic", "Pro", "Enterprise"
  price           Int             // in paise (0 for free)
  currency        String          @default("INR")
  billingCycle    String          // "monthly", "yearly"
  
  // Feature Limits
  maxMesses       Int             // 1 for free, 3 for basic, unlimited for pro
  maxMembers      Int             // 50 for free, 500 for basic, unlimited for pro
  whatsappAlerts  Boolean         @default(true)
  customBranding  Boolean         @default(false)
  advancedReporting Boolean       @default(false)
  
  description     String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  subscriptions   Subscription[]
  
  @@index([name])
}

// User Subscriptions
model Subscription {
  id                          String        @id @default(cuid())
  userId                      String
  planId                      String
  status                      String        // "active", "trial", "expired", "cancelled", "suspended"
  
  // Dates
  startDate                   DateTime
  endDate                     DateTime?
  trialEndDate                DateTime?
  renewalDate                 DateTime?
  
  // Payment Info
  razorpaySubscriptionId      String?       @unique
  razorpayCustomerId          String?
  nextBillingDate             DateTime?
  
  // Usage
  messesUsed                  Int           @default(0)
  membersUsed                 Int           @default(0)
  
  user                        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                        Plan          @relation(fields: [planId], references: [id])
  payments                    Payment[]
  
  createdAt                   DateTime      @default(now())
  updatedAt                   DateTime      @updatedAt
  
  @@index([userId])
  @@index([planId])
  @@index([status])
}

// Payment History
model Payment {
  id                          String        @id @default(cuid())
  subscriptionId              String
  razorpayPaymentId           String        @unique
  razorpayOrderId             String
  
  amount                      Int           // in paise
  currency                    String        @default("INR")
  status                      String        // "pending", "captured", "failed", "refunded"
  
  subscription                Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  
  createdAt                   DateTime      @default(now())
  updatedAt                   DateTime      @updatedAt
  
  @@index([subscriptionId])
  @@index([razorpayPaymentId])
}

// Mess (updated with userId)
model Mess {
  id                          String        @id @default(cuid())
  userId                      String        // Link to User account
  name                        String
  createdAt                   DateTime      @default(now())
  updatedAt                   DateTime      @updatedAt
  
  user                        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  members                     Member[]
  settings                    Setting[]
  
  @@index([userId])
}

model Member {
  id               String   @id @default(cuid())
  messId           String
  name             String
  mobile           String
  registrationDate DateTime @db.Date
  paymentDate      DateTime? @db.Date
  durationDays     Int      @default(30)
  amount           Int      @default(0)
  remainingAmount  Int      @default(0)
  mealsPerDay      Int      @default(2)
  plan             String   @default("Monthly meals")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  mess             Mess     @relation(fields: [messId], references: [id], onDelete: Cascade)
  renewals         MemberRenewal[]

  @@index([messId])
}

model MemberRenewal {
  id               String   @id @default(cuid())
  memberId         String
  paymentDate      DateTime @db.Date
  durationDays     Int      @default(30)
  amount           Int      @default(0)
  mealsPerDay      Int      @default(2)
  plan             String   @default("Monthly meals")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  member           Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

model Setting {
  messId    String
  key       String
  value     String
  updatedAt DateTime @updatedAt
  mess      Mess     @relation(fields: [messId], references: [id], onDelete: Cascade)

  @@id([messId, key])
  @@index([messId])
}
